# --- OS / editor noise ---------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
*~
.vscode/
.idea/
*.iml

# --- Python ---------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.tox/
.venv/
venv/
env/

# --- Node / JS (only if a future docs site is added) -----------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-store/

# --- Secrets (HARD ban — these patterns must never be committed) ----------
.env
.env.*
!.env.example
secrets/
credentials/
*.pem
*.key
*.p12
*.pfx
id_rsa
id_rsa.pub
id_ed25519
id_ed25519.pub
config/local.*
config/secrets.*

# --- Local Satellite / dry-run scratch -----------------------------------
.satellite/
satellite-cache/
tmp/
.tmp/

# --- Logs -----------------------------------------------------------------
*.log
logs/

# --- Worktrees (none expected; safety) -----------------------------------
.worktrees/

# --- Exporter: keep placeholder directories tracked ----------------------
!exports/.gitkeep
!docs/.gitkeep
!.agent/.gitkeep
!scripts/.gitkeep
!.github/.gitkeep
